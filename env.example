# NutriPlan — variabili d'ambiente
# Copia questo file in .env.local (sviluppo locale, letto da Vite) e compila i valori.
# Le variabili server-side (Vercel / Supabase Edge Functions) NON vanno in .env.local:
# vanno impostate rispettivamente in Vercel → Settings → Environment Variables e con
# `supabase secrets set NOME=valore`.

# ─── Client (Vite) — vanno in .env.local, prefisso VITE_ obbligatorio per essere
#     esposte al bundle browser. L'anon key è pubblica per design (RLS protegge i dati). ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Vercel Serverless Functions (api/*.js) — impostare su Vercel, non in .env.local ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # segreta, bypassa le RLS: mai esporla al client
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key          # segreta
VAPID_CONTACT_EMAIL=app@nutriplan.it

# ─── Supabase Edge Functions (supabase/functions/*) — impostare con `supabase secrets set` ───
# SUPABASE_URL e SUPABASE_ANON_KEY sono già forniti automaticamente dal runtime Supabase.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=app@nutriplan.it

# Provider AI per analyze-meal / daily-tips (provati in quest'ordine, il primo configurato vince)
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
